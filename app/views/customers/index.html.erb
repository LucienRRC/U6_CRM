<section class="section">
  <div class="container">
    <h1 class="title">Customers</h1>

    <nav class="buttons">
      <%= link_to "All Customers", root_path, class: "button is-link" %>
      <%= link_to "Missing Email", missing_email_customers_path, class: "button" %>
      <%= link_to "Alphabetized", alphabetized_customers_path, class: "button" %>
    </nav>

    <% if @customers.any? %>
      <%= render @customers %>
    <% else %>
      <p>No customers found.</p>
    <% end %>
  </div>
</section>
